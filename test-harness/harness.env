# L2 harness — single source of truth for the topology (subnets, IPs, ports, TURN creds).
# Read by docker-compose.yml (variable substitution) and run-interop.sh. Pinned, not dynamic, so every
# container and the orchestrator see identical values.
#
# Topology (RFC 4787 two-NAT):
#
#     peer_a ──lan_a── nat_a ══pub══ coturn / rendezvous ══pub══ nat_b ──lan_b── peer_b
#
# The peers sit behind their own NAT gateways on private LANs; they can reach coturn + rendezvous on the
# public net (through their NAT, exactly like the real internet) but NOT each other directly — that is
# what ICE establishes. The NAT profile (nat_a/nat_b) is swapped per run by run-interop.sh.

# ── networks ──
PUB_SUBNET=172.30.0.0/24
LAN_A_SUBNET=172.31.0.0/24
LAN_B_SUBNET=172.32.0.0/24
# Carrier-grade (RFC 6598 shared) address space — the extra hop between each CPE NAT and the public net
# in the double-NAT (NAT444) / hairpin lanes. Idle in the single-NAT lanes; see nat_a/nat_b + cgnat_*.
CAR_SUBNET=100.64.0.0/24

# ── public-net endpoints ──
COTURN_IP=172.30.0.10
RENDEZVOUS_IP=172.30.0.20
NAT_A_WAN_IP=172.30.0.31
NAT_B_WAN_IP=172.30.0.32

# ── private-LAN endpoints (nat_*_LAN_IP is each peer's default gateway) ──
NAT_A_LAN_IP=172.31.0.2
PEER_A_IP=172.31.0.100
NAT_B_LAN_IP=172.32.0.2
PEER_B_IP=172.32.0.100

# ── carrier-grade NAT (NAT444 / hairpin) — the EXTRA carrier hop ──
# The CPE NATs (nat_a/nat_b) each hold an address in the carrier shared space; in the cgnat/hairpin lanes
# they route the public net through a carrier NAT (cgnat_*) instead of reaching it directly, so a peer's
# reflexive candidate is the CARRIER's public IP (two translations deep). run-interop.sh points each CPE's
# NAT_*_CARRIER_GW at the right carrier NAT per scenario:
#   cgnat   → per-side carrier NATs (cgnat_a / cgnat_b), distinct public IPs, cone → traversable via srflx
#   hairpin → ONE shared carrier NAT (cgnat), symmetric mapping → both peers relay through coturn
NAT_A_CAR_IP=100.64.0.31       # nat_a's address in the carrier shared space
NAT_B_CAR_IP=100.64.0.32       # nat_b's address in the carrier shared space
CGNAT_A_CAR_IP=100.64.0.11     # cgnat_a inside (carrier-facing) address — nat_a's upstream gateway
CGNAT_A_WAN_IP=172.30.0.41     # cgnat_a public IP  → peer_a's srflx in the cgnat lane
CGNAT_B_CAR_IP=100.64.0.12     # cgnat_b inside address — nat_b's upstream gateway
CGNAT_B_WAN_IP=172.30.0.42     # cgnat_b public IP  → peer_b's srflx in the cgnat lane
CGNAT_SHARED_CAR_IP=100.64.0.10  # shared carrier NAT inside address — BOTH CPEs' upstream in the hairpin lane
CGNAT_SHARED_WAN_IP=172.30.0.40  # shared carrier NAT public IP — the single external identity both peers share
# The two /25 halves of PUB_SUBNET — more specific than the CPE's connected /24, so in carrier mode ALL
# public-net traffic (coturn, rendezvous, AND the other peer's srflx) is pulled through the carrier NAT.
CARRIER_ROUTES="172.30.0.0/25 172.30.0.128/25"

# ── ports ──
STUN_PORT=3478          # coturn STUN + TURN listener (UDP)
TURN_MIN_PORT=49160     # coturn relay allocation range (small + pinned; all intra-Docker, nothing published)
TURN_MAX_PORT=49200
RENDEZVOUS_PORT=9999    # UDP signaling keyed-mailbox relay (native/Pion peers)
RENDEZVOUS_HTTP_PORT=9998 # HTTP face onto the SAME mailbox — the browser (Chrome interop) lane, which has no raw UDP
ICE_PORT=40000          # each peer's fixed host/ICE UDP port (deterministic → NAT rules can pin it)
RELAY_BIND_PORT=40001   # each peer's TURN-allocation local bind port

# ── TURN short-term credentials (coturn static-auth) ──
TURN_REALM=webrtc.harness
TURN_USER=webrtc
TURN_PASS=webrtcpass

# ── session watchdog ── (generous: the impaired lane's establish + reliable-echo under loss is legitimately
# slower than a clean path; this is a watchdog that must not false-fail, not a wall-clock budget)
PEER_TIMEOUT_MS=90000

# ── IPv6 addressing (routed-v6 + stateful firewall — NOT NAT66) ─────────────────────────────────────
# A parallel *_IP6 for every *_IP, octet-mirrored on the v4 host part, all bridge-local so the runner needs
# no upstream v6. Inert on v4 lanes (the addresses aren't assigned unless compose.ipv6.yml is layered in;
# nat-setup.sh/coturn self-detect assignment before installing any v6 rule). Real dual-stack WebRTC over v6
# uses globally/ULA-addressed hosts behind a FILTERING firewall, never NAT66 — so the "NAT" containers
# become v6 ROUTERS (ip6tables filtering, no MASQUERADE). Consequently the RFC 4787 *mapping* dimension is
# v4-only; only the *filtering* half carries to v6 (symmetric/cgnat/hairpin/mixed-sym have no v6 analog).
#   pub ("the internet") : 2001:db8:30::/64  (RFC 3849 documentation prefix)
#   lan_a / lan_b / car  : fd00:31::/64 / fd00:32::/64 / fd00:64::/64  (RFC 4193 ULA)
PUB_SUBNET6=2001:db8:30::/64
LAN_A_SUBNET6=fd00:31::/64
LAN_B_SUBNET6=fd00:32::/64
CAR_SUBNET6=fd00:64::/64

# public-net endpoints (host octet mirrors the v4 address)
COTURN_IP6=2001:db8:30::10
RENDEZVOUS_IP6=2001:db8:30::20
NAT_A_WAN_IP6=2001:db8:30::31
NAT_B_WAN_IP6=2001:db8:30::32

# private-LAN endpoints (nat_*_LAN_IP6 is each peer's v6 default gateway)
NAT_A_LAN_IP6=fd00:31::2
PEER_A_IP6=fd00:31::100
NAT_B_LAN_IP6=fd00:32::2
PEER_B_IP6=fd00:32::100

# carrier-grade hop (v4-only lanes — no v6 analog; defined for a complete mirror, unused over v6)
NAT_A_CAR_IP6=fd00:64::31
NAT_B_CAR_IP6=fd00:64::32
CGNAT_A_CAR_IP6=fd00:64::11
CGNAT_A_WAN_IP6=2001:db8:30::41
CGNAT_B_CAR_IP6=fd00:64::12
CGNAT_B_WAN_IP6=2001:db8:30::42
CGNAT_SHARED_CAR_IP6=fd00:64::10
CGNAT_SHARED_WAN_IP6=2001:db8:30::40
